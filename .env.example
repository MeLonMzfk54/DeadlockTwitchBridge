# Twitch Application (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret

# User OAuth token with scope: channel:read:redemptions
# Generate via https://twitchtokengenerator.com/ or your own OAuth flow
TWITCH_ACCESS_TOKEN=your_user_access_token
TWITCH_REFRESH_TOKEN=your_refresh_token

# Broadcaster Twitch user ID (numeric). Leave empty to resolve from token.
TWITCH_BROADCASTER_ID=

# Game command transport: vconsole (dev/sandbox) or cfg-bind (official-safe)
GAME_COMMAND_MODE=vconsole

# cfg-bind mode (official-safe, no -insecure)
# Path to Deadlock cfg folder, e.g. C:\Program Files (x86)\Steam\steamapps\common\Deadlock\game\citadel\cfg
DEADLOCK_CFG_DIR=
CFG_BIND_FILENAME=twitch_bridge_effect.cfg
CFG_TRIGGER_KEY=F10
CFG_BIND_COMMAND_DELAY_MS=75
# Match game window by process name (deadlock.exe). Optional extra title filter.
DEADLOCK_PROCESS_NAME=deadlock
DEADLOCK_WINDOW_TITLE=

# Deadlock VConsole connection (GAME_COMMAND_MODE=vconsole)
VCONSOLE_HOST=127.0.0.1
VCONSOLE_PORT=29000
VCONSOLE_RECONNECT_MS=5000

# HTTP control panel + OBS overlay
HTTP_HOST=127.0.0.1
HTTP_PORT=3920

# Set to true to skip Twitch and use test UI / API only
TEST_MODE=false

# Allow cheat-flagged effects (not recommended for retail matchmaking)
ALLOW_CHEAT_EFFECTS=false

# Allow destructive effects (disconnect) via Twitch rewards
ALLOW_DESTRUCTIVE_EFFECTS=false

# Max queued effect activations
MAX_QUEUE_SIZE=10
